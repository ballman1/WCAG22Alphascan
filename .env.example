# ============================================================
# AACP Scanner — Environment Configuration
# Copy this to .env and fill in your Supabase credentials
# ============================================================

# Supabase Project URL (from Project Settings > API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase Service Role Key (from Project Settings > API > service_role)
# WARNING: Never expose this key in a browser or public repo
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Anon Key (for dashboard public reads)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chrome executable path (update to your system path)
# macOS (Homebrew): /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux: /usr/bin/google-chrome or /usr/bin/chromium-browser
# Docker/CI: /usr/bin/chromium
CHROME_PATH=/home/claude/.cache/puppeteer/chrome/linux-131.0.6778.204/chrome-linux64/chrome

# Scanner concurrency (parallel page scans, default 3)
SCAN_CONCURRENCY=3

# Request timeout per page in ms (default 30000)
PAGE_TIMEOUT=30000

# WCAG tag to test against (wcag2a, wcag2aa, wcag22aa)
WCAG_LEVEL=wcag22aa

# Environment
NODE_ENV=development
